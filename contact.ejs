<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - Smile Airlines</title>
    <link rel="stylesheet" href="../pros.css/contact.css">
</head>
<body>
    <header class="navbar">
        <nav class="navbar">
            <div class="logo">Smile</div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <!-- <li><a href="#flights">Flights</a></li> -->
                <li><a href="/about">About</a></li>
                <!-- <li><a href="#contact">Contact</a></li> -->
                <!-- <li><a href="">Login</a></li> -->
            </ul>
            <div class="menu-toggle" id="mobile-menu">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </div>
        </nav>
    </header>

    <main>
        <section class="contact-hero">
            <h2>Contact Us</h2>
            <p>Have questions or need assistance? We're here to help you 24/7!</p>
        </section>

        <section class="contact-info">
            <h2>Our Contact Information</h2>
            <div class="info">
                <div class="info-item">
                    <h3>Email</h3>
                    <p><a href="mailto:support@smileairlines.com">support@smileairlines.com</a></p>
                </div>
                <div class="info-item">
                    <h3>Phone</h3>
                    <p><a href="tel:+18001234567">+1 800 123 4567</a></p>
                </div>
                <div class="info-item">
                    <h3>Address</h3>
                    <p>Smile Airlines HQ, 123 Aviation Street, Indore, India</p>
                </div>
            </div>
        </section>

        <section class="contact-form-section">
            <h2>Send Us a Message</h2>
            <form action="#" method="post" class="contact-form">
                <label for="name">Your Name</label>
                <input type="text" id="name" name="name" placeholder="Enter your name" required>

                <label for="email">Your Email</label>
                <input type="email" id="email" name="email" placeholder="Enter your email" required>

                <label for="subject">Subject</label>
                <input type="text" id="subject" name="subject" placeholder="Enter the subject" required>

                <label for="message">Your Message</label>
                <textarea id="message" name="message" placeholder="Type your message here..." rows="5" required></textarea>

                <button type="submit">Submit</button>
            </form>
        </section>
    </main>

    <footer>
        <p>&copy; 2025 Smile Airlines. All rights reserved.</p>
    </footer>
</body>
</html>
